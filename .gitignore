Makefile-MK # Ignore build and IDE files

# Binaries
/bin/
/dist/
/out/
/tmp/
/.gopath/

# Build artifacts
*.exe
*.dll
*.so
*.dylib
*.test
*.log
*.crt
*.key
coverage*.out
.build/
target/
**/target/
spark-warehouse/

# Local Go cache (use GOCACHE=.gocache for hermetic builds/tests)
.gocache/
.cache/

# Go modules/vendor
/vendor/
/third_party/**

# e2e / smoke artifacts
/test/pkg/
/test/e2e/logs/

# Local notes
/notes/

# IDE/editor state
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Addon processor artifacts
addons/processors/**/bin/
addons/processors/**/dist/
addons/processors/**/out/
addons/processors/**/tmp/
addons/processors/**/.cache/
addons/processors/**/coverage*.out

# Environment/config
.env
.env.*
!.env.example
commercial-saas.md
secrets/*.yaml
secrets/*.json

# Generated assets
config/crd/bases/*.yaml
deploy/helm/kafscale/charts/
proto/**/*.pb.go
proto/**/*.swagger.json

# GitHub Pages (Jekyll) artifacts
_site/
Gemfile
Gemfile.lock

# Ignore demo node_modules
examples/E50_JS-kafscale-demo/node_modules/

# LFS demo artifacts
records.txt
e2e-client
lfs-proxy

# Kubeconfig artifacts
kubeconfig*

# Ignore custom Agents
examples/AGENTS.md


