# KafScale Synology S3 Deployment Configuration
# Copy this file to .env and adjust as needed

# Container registry
REGISTRY=192.168.0.131:5100
TAG=dev

# Synology NAS MinIO S3 Settings
# Update these if your Synology has different credentials
S3_ENDPOINT=http://192.168.0.131:9100
S3_BUCKET=kafscale
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
