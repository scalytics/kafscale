# LFS Proxy defaults (override as needed)
KAFSCALE_LFS_PROXY_LOG_LEVEL=info
KAFSCALE_LFS_PROXY_ADDR=:9092
KAFSCALE_LFS_PROXY_ADVERTISED_HOST=
KAFSCALE_LFS_PROXY_ADVERTISED_PORT=9092
KAFSCALE_LFS_PROXY_BACKENDS=
KAFSCALE_LFS_PROXY_BACKEND_RETRIES=6
KAFSCALE_LFS_PROXY_BACKEND_BACKOFF_MS=500
KAFSCALE_LFS_PROXY_BACKEND_REFRESH_INTERVAL_SEC=3
KAFSCALE_LFS_PROXY_BACKEND_CACHE_TTL_SEC=60
KAFSCALE_LFS_PROXY_DIAL_TIMEOUT_MS=5000

KAFSCALE_LFS_PROXY_HTTP_ADDR=:8080
KAFSCALE_LFS_PROXY_HTTP_API_KEY=
KAFSCALE_LFS_PROXY_HTTP_READ_TIMEOUT_SEC=30
KAFSCALE_LFS_PROXY_HTTP_WRITE_TIMEOUT_SEC=300
KAFSCALE_LFS_PROXY_HTTP_IDLE_TIMEOUT_SEC=60
KAFSCALE_LFS_PROXY_HTTP_HEADER_TIMEOUT_SEC=10
KAFSCALE_LFS_PROXY_HTTP_MAX_HEADER_BYTES=1048576
KAFSCALE_LFS_PROXY_HTTP_SHUTDOWN_TIMEOUT_SEC=10
KAFSCALE_LFS_PROXY_TOPIC_MAX_LENGTH=249

KAFSCALE_LFS_PROXY_HEALTH_ADDR=:9094
KAFSCALE_LFS_PROXY_METRICS_ADDR=:9095

KAFSCALE_LFS_PROXY_ETCD_ENDPOINTS=
KAFSCALE_LFS_PROXY_ETCD_USERNAME=
KAFSCALE_LFS_PROXY_ETCD_PASSWORD=

KAFSCALE_LFS_PROXY_S3_BUCKET=
KAFSCALE_LFS_PROXY_S3_REGION=
KAFSCALE_LFS_PROXY_S3_ENDPOINT=
KAFSCALE_LFS_PROXY_S3_ACCESS_KEY=
KAFSCALE_LFS_PROXY_S3_SECRET_KEY=
KAFSCALE_LFS_PROXY_S3_SESSION_TOKEN=
KAFSCALE_LFS_PROXY_S3_FORCE_PATH_STYLE=false
KAFSCALE_LFS_PROXY_S3_ENSURE_BUCKET=false
KAFSCALE_LFS_PROXY_S3_HEALTH_INTERVAL_SEC=30
KAFSCALE_LFS_PROXY_MAX_BLOB_SIZE=5368709120
KAFSCALE_LFS_PROXY_CHUNK_SIZE=5242880
KAFSCALE_LFS_PROXY_ID=
KAFSCALE_S3_NAMESPACE=default
KAFSCALE_LFS_PROXY_CHECKSUM_ALGO=sha256

# LFS demo defaults
MINIO_IMAGE=minio/minio:latest
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
LFS_PROXY_KAFKA_PORT=9092
LFS_PROXY_HTTP_PORT=8080
LFS_PROXY_METRICS_PORT=9095
LFS_PROXY_HTTP_PATH=/lfs/produce
LFS_PROXY_SERVICE_HOST=
MINIO_SERVICE_HOST=
MINIO_ENDPOINT=
LFS_PROXY_HTTP_URL=
LFS_PROXY_S3_REGION=us-east-1
LFS_PROXY_S3_FORCE_PATH_STYLE=true
LFS_PROXY_S3_ENSURE_BUCKET=true

# LFS demo script defaults
LFS_DEMO_NAMESPACE=kafscale-demo
LFS_DEMO_TOPIC=lfs-demo-topic
LFS_DEMO_BLOB_SIZE=10485760
LFS_DEMO_BLOB_COUNT=5
LFS_DEMO_TIMEOUT_SEC=120
LFS_PROXY_LOG_LEVEL=debug
LFS_PROXY_BACKENDS=
LFS_PROXY_ETCD_ENDPOINTS=
LFS_PROXY_ADVERTISED_HOST=
LFS_PROXY_ADVERTISED_PORT=9092
LFS_PROXY_S3_FORCE_PATH_STYLE=true
LFS_PROXY_S3_ENSURE_BUCKET=true
KAFSCALE_S3_NAMESPACE=default
LFS_PROXY_SERVICE_HOST=
BROKER_SERVICE_HOST=
ETCD_SERVICE_HOST=
MINIO_SERVICE_HOST=
MINIO_ENDPOINT=
METRICS_LOCAL_PORT=19095
BUSYBOX_IMAGE=busybox:1.36

# Shared demo infrastructure
LFS_PROXY_IMAGE=ghcr.io/kafscale/kafscale-lfs-proxy:latest
E2E_CLIENT_IMAGE=ghcr.io/kafscale/kafscale-e2e-client:latest
MINIO_BUCKET=kafscale-lfs
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Industrial LFS demo defaults
INDUSTRIAL_DEMO_NAMESPACE=kafscale-industrial
INDUSTRIAL_DEMO_TELEMETRY_COUNT=20
INDUSTRIAL_DEMO_IMAGE_COUNT=3
INDUSTRIAL_DEMO_IMAGE_SIZE=52428800
INDUSTRIAL_DEMO_CLEANUP=1
INDUSTRIAL_DEMO_TIMEOUT=300
TOPIC_TELEMETRY=sensor-telemetry
TOPIC_IMAGES=inspection-images
TOPIC_DEFECTS=defect-events
TOPIC_REPORTS=quality-reports

# Medical LFS demo defaults
MEDICAL_DEMO_NAMESPACE=kafscale-medical
MEDICAL_DEMO_BLOB_SIZE=524288000
MEDICAL_DEMO_BLOB_COUNT=3
MEDICAL_DEMO_CLEANUP=1
MEDICAL_DEMO_TIMEOUT=300
TOPIC_IMAGES=medical-images
TOPIC_METADATA=medical-metadata
TOPIC_AUDIT=medical-audit

# Video LFS demo defaults
VIDEO_DEMO_NAMESPACE=kafscale-video
VIDEO_DEMO_BLOB_SIZE=104857600
VIDEO_DEMO_BLOB_COUNT=2
VIDEO_DEMO_CLEANUP=1
VIDEO_DEMO_TIMEOUT=300
TOPIC_RAW=video-raw
TOPIC_METADATA=video-metadata
TOPIC_FRAMES=video-frames
TOPIC_AI=video-ai-tags

# Backend TLS/SASL
KAFSCALE_LFS_PROXY_BACKEND_TLS_ENABLED=false
KAFSCALE_LFS_PROXY_BACKEND_TLS_CA_FILE=
KAFSCALE_LFS_PROXY_BACKEND_TLS_CERT_FILE=
KAFSCALE_LFS_PROXY_BACKEND_TLS_KEY_FILE=
KAFSCALE_LFS_PROXY_BACKEND_TLS_SERVER_NAME=
KAFSCALE_LFS_PROXY_BACKEND_TLS_INSECURE_SKIP_VERIFY=false
KAFSCALE_LFS_PROXY_BACKEND_SASL_MECHANISM=
KAFSCALE_LFS_PROXY_BACKEND_SASL_USERNAME=
KAFSCALE_LFS_PROXY_BACKEND_SASL_PASSWORD=

# HTTP TLS
KAFSCALE_LFS_PROXY_HTTP_TLS_ENABLED=false
KAFSCALE_LFS_PROXY_HTTP_TLS_CERT_FILE=
KAFSCALE_LFS_PROXY_HTTP_TLS_KEY_FILE=
KAFSCALE_LFS_PROXY_HTTP_TLS_CLIENT_CA_FILE=
KAFSCALE_LFS_PROXY_HTTP_TLS_REQUIRE_CLIENT_CERT=false

# IDoc explode processor
# Iceberg processor LFS integration
KAFSCALE_ICEBERG_LFS_MODE=off
KAFSCALE_ICEBERG_LFS_MAX_INLINE_SIZE=1048576
KAFSCALE_ICEBERG_LFS_STORE_METADATA=false
KAFSCALE_ICEBERG_LFS_VALIDATE_CHECKSUM=true
KAFSCALE_ICEBERG_LFS_RESOLVE_CONCURRENCY=4

KAFSCALE_IDOC_OUTPUT_DIR=idoc-output
KAFSCALE_IDOC_ITEM_SEGMENTS=E1EDP01,E1EDP19
KAFSCALE_IDOC_PARTNER_SEGMENTS=E1EDKA1
KAFSCALE_IDOC_STATUS_SEGMENTS=E1STATS
KAFSCALE_IDOC_DATE_SEGMENTS=E1EDK03
KAFSCALE_IDOC_TOPIC_HEADER=idoc-headers
KAFSCALE_IDOC_TOPIC_SEGMENTS=idoc-segments
KAFSCALE_IDOC_TOPIC_ITEMS=idoc-items
KAFSCALE_IDOC_TOPIC_PARTNERS=idoc-partners
KAFSCALE_IDOC_TOPIC_STATUS=idoc-status
KAFSCALE_IDOC_TOPIC_DATES=idoc-dates
KAFSCALE_IDOC_MAX_BLOB_SIZE=0
KAFSCALE_IDOC_VALIDATE_CHECKSUM=true

